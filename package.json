{
  "name": "enumeration",
  "homepage": "http://vladimino.github.io/enumeration/",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "dependencies": {
    "axios": "^1.13.2",
    "js-cookie": "^3.0.5",
    "prop-types": "^15.8.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.1",
    "semantic-ui-react": "^2.1.5"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build && cp dist/index.html dist/404.html",
    "preview": "vite preview",
    "test": "vitest run",
    "prepare": "husky",
    "check-code-style": "prettier --trailing-comma es5 --end-of-line lf --no-semi --no-bracket-spacing --jsx-single-quote --single-quote --check \"src/**/*.{js,jsx}\"",
    "prettier": "prettier --trailing-comma es5 --end-of-line lf --no-semi --no-bracket-spacing --jsx-single-quote --single-quote --write \"src/**/*.{js,jsx}\""
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.7.0",
    "husky": "^9.1.7",
    "jsdom": "^26.1.0",
    "lint-staged": "^16.2.7",
    "prettier": "^3.6.2",
    "vite": "^6.4.1",
    "vitest": "^3.2.4"
  },
  "lint-staged": {
    "src/**/*.{js,jsx}": "npm run prettier"
  }
}
